# =============================================================================
# QuickBooks Online MCP server - environment configuration
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# =============================================================================

# --- OAuth2 app credentials --------------------------------------------------
# Where to get these:
#   1. Sign in at https://developer.intuit.com and open the Developer Dashboard.
#   2. Create an app under "My Apps" and select the "Accounting" (QuickBooks
#      Online Accounting API) scope.
#   3. Open the app -> "Keys & credentials". There are two credential sets:
#        - "Development" keys  -> use with QBO_ENVIRONMENT=sandbox
#        - "Production" keys    -> use with QBO_ENVIRONMENT=production
#   4. Copy the Client ID and Client Secret for the environment you want.
QBO_CLIENT_ID=your_client_id_here
QBO_CLIENT_SECRET=your_client_secret_here

# --- OAuth2 refresh token ----------------------------------------------------
# This is the long-lived token used to mint short-lived access tokens.
# How to obtain it (one time):
#   Easiest: Intuit OAuth 2.0 Playground -> https://developer.intuit.com/app/developer/playground
#     - Select your app, choose the "com.intuit.quickbooks.accounting" scope,
#       click through the authorization, and copy the "Refresh Token" it returns.
#     - The Playground also shows the Realm ID (company id) - copy it below.
#   Or programmatically with the intuit-oauth (intuitlib) library:
#       from intuitlib.client import AuthClient
#       from intuitlib.enums import Scopes
#       ac = AuthClient(CLIENT_ID, CLIENT_SECRET, REDIRECT_URI, 'sandbox')
#       url = ac.get_authorization_url([Scopes.ACCOUNTING])   # visit, approve
#       ac.get_bearer_token(auth_code, realm_id=realm_id)      # from the redirect
#       print(ac.refresh_token, ac.realm_id)
# NOTE: Intuit ROTATES this token on every refresh (old one is valid ~24h after
# rotation; each refresh token expires after ~100 days if unused). Set
# QBO_TOKEN_CACHE_FILE below so the server persists the rotated token across
# restarts instead of falling back to this (possibly stale) value.
QBO_REFRESH_TOKEN=your_refresh_token_here

# --- Realm / Company ID ------------------------------------------------------
# The QBO company ("realm") to post into. Found in the OAuth Playground output,
# or in QBO: Gear icon -> "Account and settings" -> Billing & Subscription shows
# the Company ID. Sandbox companies list their realm id in the developer sandbox.
QBO_REALM_ID=your_realm_id_here

# --- Environment -------------------------------------------------------------
# sandbox    -> https://sandbox-quickbooks.api.intuit.com (use Development keys)
# production -> https://quickbooks.api.intuit.com          (use Production keys)
QBO_ENVIRONMENT=sandbox

# --- API minor version (optional) --------------------------------------------
# Pins the QBO response/field schema. 70 is a broadly-available stable value.
# See Intuit's "minor versions" changelog for the current maximum.
QBO_MINOR_VERSION=70

# --- Rotating refresh-token cache (optional but recommended) -----------------
# Absolute path to a small JSON file the server writes the newest refresh token
# to after each refresh, so restarts don't reuse a rotated-out token. Keep this
# file out of version control and readable only by the service user.
# QBO_TOKEN_CACHE_FILE=/var/lib/quickbooks-mcp/token-cache.json
